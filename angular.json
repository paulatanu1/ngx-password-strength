{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "ngx-password-strength": {
      "projectType": "library",
      "root": "projects/ngx-password-strength",
      "sourceRoot": "projects/ngx-password-strength/src",
      "prefix": "ngx",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ngx-password-strength/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ngx-password-strength/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ngx-password-strength/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "demo": {
      "projectType": "application",
      "root": "projects/demo",
      "sourceRoot": "projects/demo/src",
      "prefix": "demo",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/demo/src/main.ts",
            "index": "projects/demo/src/index.html",
            "tsConfig": "projects/demo/tsconfig.app.json",
            "polyfills": ["zone.js"],
            "outputPath": "dist/demo"
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4200
          },
          "configurations": {
            "production": { "buildTarget": "demo:build:production" },
            "development": { "buildTarget": "demo:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
